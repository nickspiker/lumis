<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="android:Theme.NoTitleBar">
        <item name="android:immersive">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
        <item name="android:colorBackground">#000000</item>
        <item name="android:textColorPrimary">#FFFFFF</item>
        <item name="android:textColorSecondary">#CCCCCC</item>
        
        <!-- Splash screen customization for Android 12+ -->
        <item name="android:windowSplashScreenBackground">#000000</item>
        <item name="android:windowSplashScreenAnimationDuration">0</item>
        
        <!-- Force dark background before splash -->
        <item name="android:windowBackground">#000000</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <!-- Dark dialog theme -->
    <style name="DarkDialogTheme" parent="android:Theme.Dialog">
        <item name="android:background">#1a1a1a</item>
        <item name="android:textColorPrimary">#FFFFFF</item>
        <item name="android:textColorSecondary">#CCCCCC</item>
        <item name="android:colorBackground">#1a1a1a</item>
        <item name="android:windowBackground">#1a1a1a</item>
    </style>

</resources>